TELEGRAM_BOT_TOKEN=        # @BotFather → /newbot → copy token
GROQ_API_KEY=              # console.groq.com → free signup → create key (starts with gsk_)
SUPABASE_URL=              # app.supabase.com → create your own project → Settings → API → Project URL
SUPABASE_ANON_KEY=         # same location → anon public key
PINECONE_API_KEY=          # pinecone.io → free signup → API Keys tab → copy key (starts with pcsk_)
PINECONE_INDEX_NAME=ai-agent-platform  # must match the index name you created in Pinecone
PINECONE_NAMESPACE=biz_intern_receptionist  # unique namespace for your FAQ data
BIZ_NAME=City Clinic       # change to your clinic/business name
