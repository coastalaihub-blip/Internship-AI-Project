# Dashboard uses browser JS — paste credentials directly into app.js instead of here
# (Browser JS cannot read .env files)
#
# Open dashboard/app.js and set:
#   const SUPABASE_URL = "https://your-project.supabase.co";
#   const SUPABASE_ANON_KEY = "eyJhbGci...";
#
# Use ANON KEY only (not service_role key) — safe to expose in browser JS
